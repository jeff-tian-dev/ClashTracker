# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Oracle Cloud Server (Ubuntu 24.04) — runs backend API + ingestion
ORACLE_SERVER_IP=
ORACLE_SSH_KEY_PATH=./ssh-key.key

# Clash of Clans API (developer.clashofclans.com) — IP-whitelisted to Oracle server
COC_API_TOKEN=your-coc-api-token

# Optional: domain for HTTPS (enables GitHub Pages). Set after running deploy/setup-https.sh
# API_DOMAIN=https://clashtracker.duckdns.org

# Optional: additional CORS origins (comma-separated) for the backend API
# CORS_ORIGINS=http://example.com,https://your-app.vercel.app

# Optional: admin key for delete operations (generate with: openssl rand -hex 32)
# ADMIN_API_KEY=
